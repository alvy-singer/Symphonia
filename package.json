    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.460.0",
    "next": "15.1.11",
    "onborda": "^1.2.5",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "remotion": "4.0.467",
