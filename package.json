    "video:render:clarise": "remotion render remotion/index.ts ClariseMilestone out/clarise-milestone.mp4",
    "video:render:task-review": "remotion render remotion/index.ts TaskToReview out/task-to-review.mp4",
    "video:render:automation": "remotion render remotion/index.ts AutomationControlled out/automation-controlled.mp4",
    "video:render:all": "npm run video:render:connect && npm run video:render:clarise && npm run video:render:task-review && npm run video:render:automation",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.4",
